<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <!-- Maintenance List View -->
    <record id="view_assetflow_maintenance_list" model="ir.ui.view">
        <field name="name">assetflow.maintenance.list</field>
        <field name="model">assetflow.maintenance</field>
        <field name="arch" type="xml">
            <list string="Maintenance Records">
                <field name="asset_id"/>
                <field name="service_date"/>
                <field name="issue"/>
                <field name="technician"/>
                <field name="cost"/>
                <field name="status"/>
            </list>
        </field>
    </record>


    <!-- Maintenance Form View -->
    <record id="view_assetflow_maintenance_form" model="ir.ui.view">
        <field name="name">assetflow.maintenance.form</field>
        <field name="model">assetflow.maintenance</field>
        <field name="arch" type="xml">

            <form string="Maintenance">

                <sheet>

                    <group>
                        <group>
                            <field name="asset_id"/>
                            <field name="service_date"/>
                            <field name="status"/>
                        </group>

                        <group>
                            <field name="technician"/>
                            <field name="cost"/>
                        </group>
                    </group>

                    <group string="Maintenance Details">
                        <field name="issue"/>
                        <field name="notes"/>
                    </group>

                </sheet>

            </form>

        </field>
    </record>


    <!-- Maintenance Action -->
    <record id="action_assetflow_maintenance" model="ir.actions.act_window">
        <field name="name">Maintenance</field>
        <field name="res_model">assetflow.maintenance</field>
        <field name="view_mode">list,form</field>
    </record>


    <!-- Maintenance Menu -->
    <menuitem
        id="menu_assetflow_maintenance"
        name="Maintenance"
        parent="menu_assetflow_root"
        action="action_assetflow_maintenance"
        sequence="20"
    />

</odoo>