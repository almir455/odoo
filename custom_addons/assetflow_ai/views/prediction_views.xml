<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <record id="view_assetflow_prediction_list" model="ir.ui.view">
        <field name="name">assetflow.prediction.list</field>
        <field name="model">assetflow.prediction</field>
        <field name="arch" type="xml">
            <list string="AI Predictions">
                <field name="asset_id"/>
                <field name="failure_probability"/>
                <field name="health_score"/>
                <field name="risk_level"/>
                <field name="prediction_date"/>
            </list>
        </field>
    </record>

    <record id="view_assetflow_prediction_form" model="ir.ui.view">
        <field name="name">assetflow.prediction.form</field>
        <field name="model">assetflow.prediction</field>
        <field name="arch" type="xml">
            <form string="AI Prediction">
                <sheet>
                    <group>
                        <group>
                            <field name="asset_id"/>
                            <field name="failure_probability"/>
                            <field name="health_score"/>
                        </group>

                        <group>
                            <field name="risk_level"/>
                            <field name="prediction_date"/>
                        </group>
                    </group>

                    <group string="AI Recommendation">
                        <field name="recommended_action"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_assetflow_predictions" model="ir.actions.act_window">
        <field name="name">AI Predictions</field>
        <field name="res_model">assetflow.prediction</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_assetflow_predictions"
        name="AI Predictions"
        parent="menu_assetflow_root"
        action="action_assetflow_predictions"
        sequence="40"
    />

</odoo>